# Copy this file to `.streamlit/secrets.toml` for local use.
# On Streamlit Community Cloud, paste these same keys/values into
# your app's "Secrets" settings instead of committing a real secrets.toml.
#
# .streamlit/secrets.toml is gitignored — never commit real secrets.

# Required to use the in-app "Refresh data now" admin control.
# Pick any long random string; treat it like a password.
ADMIN_REFRESH_TOKEN = "change-me-to-a-long-random-string"
